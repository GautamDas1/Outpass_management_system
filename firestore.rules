rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if request is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Students collection
    match /students/{studentId} {
      allow read: if isAuth();
      allow write: if isAuth(); // restrict further in production
    }

    // Staff collection
    match /staff/{staffId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Gatekeepers collection
    match /gatekeepers/{gatekeeperId} {
      allow read: if true; // gatekeeper login happens client-side
      allow write: if isAuth();
    }

    // Outpasses collection
    match /outpasses/{outpassId} {
      allow read: if isAuth() || true; // gatekeeper needs read
      allow create: if isAuth();
      allow update: if isAuth() || true;
    }

    // Announcements collection
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAuth();
    }
  }
}
